# AUTOTEST Production Environment Variables
# Copy this to .env.prod and fill with production values

# Database
DB_USER=autotest_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=autotest_prod
EXPECTED_DATABASE_NAME=autotest_prod

# Security
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY_64_CHARS_MIN

# Payment Integration (TsPay)
TSPAY_ACCESS_TOKEN=your_production_tspay_token
TSPAY_WEBHOOK_SECRET=your_production_webhook_secret

# Application
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# Optional: Email, etc. (add as needed)