# AUTOTEST Production Environment Variables
# Copy this to .env and fill with production values
# ALL variables marked [REQUIRED] MUST be set for production

# ============================================================================
# DATABASE CONFIGURATION [REQUIRED]
# ============================================================================
DB_USER=autotest_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=autotest_prod
EXPECTED_DATABASE_NAME=autotest_prod
DATABASE_URL=postgresql+asyncpg://autotest_prod:CHANGE_THIS_STRONG_PASSWORD@db:5432/autotest_prod

# ============================================================================
# SECURITY [REQUIRED]
# ============================================================================
# 64+ character random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY_64_CHARS_MIN
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# ============================================================================
# EMAIL CONFIGURATION [REQUIRED for email features]
# ============================================================================
# Using Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=noreply@autotest.uz
EMAIL_TIMEOUT_SECONDS=12.0

# Alternative: Using Resend.dev (email service)
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
APP_NAME=AUTOTEST
ENABLE_API_DOCS=false
ENABLE_EMAIL_VERIFICATION=true
REQUIRE_EMAIL_VERIFICATION=false

# ============================================================================
# PAYMENT INTEGRATION - TSPay (REQUIRED) [REQUIRED]
# ============================================================================
TSPAY_API_BASE_URL=https://tspay.uz/api/v1
TSPAY_ACCESS_TOKEN=your_production_tspay_access_token
TSPAY_MERCHANT_ACCESS_TOKEN=your_production_tspay_merchant_token
TSPAY_WEBHOOK_SECRET=your_production_tspay_webhook_secret
TSPAY_REQUIRE_WEBHOOK_SIGNATURE=true
TSPAY_REQUEST_TIMEOUT_SECONDS=10.0

# Payment URLs (redirect after payment)
FRONTEND_SUCCESS_URL=https://app.autotest.uz/payment/success
FRONTEND_CANCEL_URL=https://app.autotest.uz/payment/cancel
PREMIUM_PRICE_UZS=100000

# Legacy Stripe (optional, for backward compatibility)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ============================================================================
# CORS - Allowed Frontend Origins
# ============================================================================
ALLOWED_ORIGINS=https://app.autotest.uz,https://www.autotest.uz,https://autotest.uz

# ============================================================================
# MONITORING & LOGGING (Optional but recommended)
# ============================================================================
# Sentry for error tracking
SENTRY_DSN=https://your_sentry_key@sentry.io/your_project_id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=1.0.0

# ============================================================================
# ML FEATURES (Optional)
# ============================================================================
ML_ADMIN_PASSWORD=admin_password_to_access_ml_dashboard
ML_ADMIN_SESSION_HOURS=12

# ============================================================================
# DATABASE BACKUP SETTINGS (Optional)
# ============================================================================
BACKUP_DIR=/app/backups
BACKUP_RETENTION_COUNT=14
PG_DUMP_PATH=pg_dump