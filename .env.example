SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/autotest
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://165.232.160.172:3000

# Legacy Stripe placeholders (not used by TsPay flow)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# TsPay merchant integration
TSPAY_API_BASE_URL=https://tspay.uz/api/v1
TSPAY_CREATE_TRANSACTION_PATH=/transactions/create/
TSPAY_TRANSACTION_STATUS_PATH_TEMPLATE=/transactions/{cheque_id}/
# Preferred auth key used by current provider:
TSPAY_ACCESS_TOKEN=
# Optional alias (provider now accepts this as fallback too):
TSPAY_MERCHANT_KEY=
TSPAY_MERCHANT_ID=
TSPAY_MERCHANT_EMAIL=
TSPAY_MERCHANT_PASSWORD=
TSPAY_WEBHOOK_SECRET=
TSPAY_REQUIRE_WEBHOOK_SIGNATURE=false
TSPAY_WEBHOOK_TOLERANCE_SECONDS=300
TSPAY_REQUEST_TIMEOUT_SECONDS=10

FRONTEND_SUCCESS_URL=http://localhost:3000/payment/success
FRONTEND_CANCEL_URL=http://localhost:3000/payment/cancel

# Email Settings
# Resend API (recommended on cloud servers where SMTP ports are blocked)
RESEND_API_KEY=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# Resend productionda "from" manzil verified domain/email bo'lishi shart.
# Sandbox/dev holatda onboarding@resend.dev ishlatilishi mumkin.
EMAIL_FROM=your-email@gmail.com
# Optional aliases (some panels export these names instead)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Fallback premium amount when no active plan is found (tiyin-style cents)
PREMIUM_PRICE_UZS=100000
