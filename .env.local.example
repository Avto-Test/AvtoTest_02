# AUTOTEST Local Environment Variables
# Copy this to .env.local for local Docker development

# Database (matches docker-compose.local.yml)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/autotest

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security (for local development only)
SECRET_KEY=dev-secret-key-change-in-production

# Payment (use test credentials)
TSPAY_ACCESS_TOKEN=test_token
TSPAY_WEBHOOK_SECRET=test_secret

# Frontend URLs
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000