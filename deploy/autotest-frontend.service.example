[Unit]
Description=AUTOTEST Frontend (Next.js)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Loyiha_003.1/frontend
EnvironmentFile=/root/Loyiha_003.1/frontend/.env.local
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
