# AUTOTEST Frontend Environment Variables

# Public API base path (proxied by Nginx to FastAPI)
NEXT_PUBLIC_API_BASE=/api

# Backend API URL for server-side Next.js routes (middleware, route handlers)
API_URL=http://localhost:8000

# Database URL for Next.js API routes (analytics tracking)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autotest

# Optional app base URL for payment redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TsPay merchant integration (optional for frontend-side provider utilities)
# Main payment flow should use backend /api/payments/* endpoints.
TSPAY_API_BASE_URL=https://tspay.uz/api/v1
TSPAY_CREATE_SESSION_PATH=/transactions/create/
TSPAY_ACCESS_TOKEN=
TSPAY_MERCHANT_KEY=
TSPAY_MERCHANT_ID=
TSPAY_MERCHANT_EMAIL=
TSPAY_MERCHANT_PASSWORD=
TSPAY_WEBHOOK_SECRET=
TSPAY_WEBHOOK_TOLERANCE_SECONDS=300
TSPAY_REQUEST_TIMEOUT_MS=12000
TSPAY_PRO_PRICE_CENTS=1000
TSPAY_SUCCESS_URL=http://localhost:3000/dashboard?upgraded=true
TSPAY_CANCEL_URL=http://localhost:3000/upgrade?canceled=true
